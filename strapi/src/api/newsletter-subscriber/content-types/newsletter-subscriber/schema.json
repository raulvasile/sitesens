{
  "kind": "collectionType",
  "collectionName": "newsletter_subscribers",
  "info": {
    "singularName": "newsletter-subscriber",
    "pluralName": "newsletter-subscribers",
    "displayName": "👥 Abonat Newsletter",
    "description": "Abonați newsletter — double opt-in, GDPR"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "name": {
      "type": "string"
    },
    "consent_date": {
      "type": "datetime",
      "required": true
    },
    "source": {
      "type": "string",
      "default": "website"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "unsubscribed"],
      "default": "pending",
      "required": true
    },
    "ip_address": {
      "type": "string",
      "private": true
    }
  }
}
