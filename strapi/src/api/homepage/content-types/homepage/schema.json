{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Conținutul paginii principale"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "hero_title": {
      "type": "string",
      "required": true
    },
    "hero_subtitle": {
      "type": "text"
    },
    "hero_cta_text": {
      "type": "string",
      "default": "Înscrie-te"
    },
    "hero_cta_link": {
      "type": "string",
      "default": "/inscrie-te"
    },
    "hero_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "values": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.value-card"
    },
    "program_points": {
      "type": "component",
      "repeatable": true,
      "component": "blocks.program-item"
    },
    "newsletter_title": {
      "type": "string",
      "default": "Rămâi la curent"
    },
    "newsletter_description": {
      "type": "text"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
