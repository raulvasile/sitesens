{
  "kind": "collectionType",
  "collectionName": "member_profiles",
  "info": {
    "singularName": "member-profile",
    "pluralName": "member-profiles",
    "displayName": "Member Profile",
    "description": "Profil membru partid — aderare, card digital, gamification"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "membership_type": {
      "type": "enumeration",
      "enum": ["simpatizant", "membru", "moderator"],
      "default": "simpatizant",
      "required": true
    },
    "card_number": {
      "type": "string",
      "unique": true
    },
    "filial": {
      "type": "string"
    },
    "joined_date": {
      "type": "date"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "active", "suspended"],
      "default": "pending",
      "required": true
    },
    "gamification_data": {
      "type": "json"
    }
  }
}
