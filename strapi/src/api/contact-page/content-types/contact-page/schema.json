{
  "kind": "singleType",
  "collectionName": "contact_pages",
  "info": {
    "singularName": "contact-page",
    "pluralName": "contact-pages",
    "displayName": "⚙️ Contact",
    "description": "Pagina de contact — date, formular, newsletter"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "default": "Contact"
    },
    "subtitle": {
      "type": "text"
    },
    "email": {
      "type": "email",
      "default": "contact@partidulsens.ro"
    },
    "address": {
      "type": "text"
    },
    "schedule": {
      "type": "string"
    },
    "newsletter_title": {
      "type": "string"
    },
    "newsletter_description": {
      "type": "text"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
