{
  "kind": "collectionType",
  "collectionName": "membership_requests",
  "info": {
    "singularName": "membership-request",
    "pluralName": "membership-requests",
    "displayName": "👥 Cerere Aderare",
    "description": "Cereri de aderare la Partidul SENS"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "first_name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "minLength": 1
    },
    "last_name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "minLength": 1
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true,
      "maxLength": 254
    },
    "phone": {
      "type": "string",
      "required": true,
      "maxLength": 20,
      "regex": "^(\\+?4)?0[0-9]{9}$"
    },
    "birth_date": {
      "type": "date",
      "required": true
    },
    "county": {
      "type": "string",
      "required": true,
      "maxLength": 50
    },
    "city": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "address": {
      "type": "text",
      "required": true,
      "maxLength": 500
    },
    "motivation": {
      "type": "text",
      "maxLength": 1000
    },
    "interests": {
      "type": "json"
    },
    "consent_gdpr": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "consent_statute": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "consent_data_processing": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "consent_newsletter": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "approved", "rejected"],
      "default": "pending",
      "required": true
    },
    "notes": {
      "type": "text",
      "private": true,
      "maxLength": 2000
    }
  }
}
